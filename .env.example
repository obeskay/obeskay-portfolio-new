# Coolify Deployment Configuration
# Copy this to .env.local and fill in your actual values
#
# IMPORTANT: Never commit .env.local to Git!

# =============================================================================
# COOLIFY API CONFIGURATION
# =============================================================================

# Coolify instance URL (no trailing slash)
COOLIFY_URL="https://admin.cloud.obeskay.com"

# Your application ID in Coolify
# Find this in: Coolify Dashboard → Applications → Your App → URL contains the ID
PORTFOLIO_APP_ID="your-application-id-here"

# Coolify API Bearer Token
# Generate in: Coolify Dashboard → Settings → API Tokens → Create New Token
# Format: 18|xxxxxxxxxxxxxxxxxxxxxxxx
BEARER_TOKEN="your-bearer-token-here"

# =============================================================================
# DEPLOYMENT TARGETS
# =============================================================================

# Production domain (where the site is live)
PORTFOLIO_DOMAIN="https://obeskay.com"

# Git remote name (usually 'origin')
GIT_REMOTE="origin"

# Git branch to deploy from
GIT_BRANCH="main"

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# How often to check deployment status (in seconds)
CHECK_INTERVAL=60

# Maximum number of status check attempts
MAX_ATTEMPTS=10
